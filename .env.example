# Copy to .env (gitignored) and fill in. Never commit real secrets.
# The server validates this at boot (server/env.js) and refuses to start if a
# REQUIRED var is missing or JWT_SECRET is too short.
#
# Deploy checklist: set every REQUIRED var (and RESEND_API_KEY in production) in
# the Vercel project settings, not just locally.

# REQUIRED — Neon Postgres connection string (Step 1)
DATABASE_URL=

# REQUIRED — secret used to sign JWTs (Step 2). Use a long random string
# (≥ 32 chars; the project uses 64). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Email verification via Resend (Step 2/9).
# Optional in dev: codes log to the server console.
# REQUIRED in production: without it, signup fails loudly (no silent fallback).
RESEND_API_KEY=

# Sender address for verification emails. Must be on a domain verified in Resend.
# REQUIRED in production: the resend.dev fallback only delivers to the account
# owner. Example: Swap <noreply@mail.hereweswap.com>
EMAIL_FROM=

# Vercel Blob image uploads (Step 4). Needed for listing photos.
BLOB_READ_WRITE_TOKEN=
