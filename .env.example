# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Neon Postgres connection string (Step 1)
DATABASE_URL=

# Auth — secret used to sign JWTs (Step 2). Use a long random string.
JWT_SECRET=

# Email verification via Resend (Step 2/9). Optional in dev: codes log to console.
RESEND_API_KEY=

# Vercel Blob image uploads (Step 4)
BLOB_READ_WRITE_TOKEN=
